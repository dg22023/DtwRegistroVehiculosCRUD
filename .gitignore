# Includes: html, css, javascript

### Universal ###
# Common files that should be ignored in all projects

# Logs
*.log
# Temporary files
*.tmp
*~

*.bak
# Environment files (containing secrets, API keys, credentials)
.env
*.env
.env.*

# Local configuration that shouldn't be shared
*.local

### OS ###
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

### IDEs ###
.vscode/
.idea/
*.swp
*.swo

### Html ###
# html specific files

### Css ###
# css specific files

*.css.map
.sass-cache/
*.scssc

### Javascript ###
# javascript specific files

node_modules/
*.log
npm-debug.log*
yarn-debug.log*
.cache/

dist/
coverage/
